{
  "name": "codecache-cli",
  "version": "0.1.0",
  "description": "Local-first CLI for storing and retrieving code snippets.",
  "license": "MIT",
  "bin": {
    "cache": "./bin/cache.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "node ./bin/cache.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "dependencies": {
    "module-alias": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
